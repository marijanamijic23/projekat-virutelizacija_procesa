<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>

	<system.serviceModel>
		<client>
			<endpoint name="DroneTcpBinding"
				  address="net.tcp://localhost:4002/ServiceDrone"
				  binding="netTcpBinding"
			      bindingConfiguration="DroneTcpBinding"
				  contract="Common.IDroneService" />
		</client>
		<bindings>
			<netTcpBinding>
				<binding name="DroneTcpBinding"
						 maxReceivedMessageSize="2147483647"
						 sendTimeout="00:01:00"
						 receiveTimeout="00:10:00"
						 />
			</netTcpBinding>
		</bindings>
	</system.serviceModel>
	
</configuration>