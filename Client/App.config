<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>

	<system.serviceModel>
		<client>
			<endpoint name="DroneService"
				  address="net.tcp://localhost:4002/ServiceDrone"
				  binding="netTcpBinding"
				  contract="Common.IDrone" />
		</client>
	</system.serviceModel>
	
</configuration>